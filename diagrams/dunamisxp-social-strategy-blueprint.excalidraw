d","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"p3-pct","x":2230,"y":2245,"width":55,"height":25,"text":"15%","originalText":"15%","fontSize":22,"fontFamily":1,"textAlign":"right","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#2f9e44","backgroundColor":"transparent","seed":188,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"p3-body","x":1765,"y":2300,"width":520,"height":350,"text":"The comeback narrative (slept in car)\n29 years of experience stories\nFaith journey tied to fitness\nBehind-the-scenes training\nDay-in-the-life content\n\nFORMAT: Storytelling with\nemotional vulnerability\n\nEXAMPLE HOOKS:\n'I slept in my car at 30. At 48...'\n'What 29 years of training taught me'\n'The day I almost quit fitness'","originalText":"The comeback narrative (slept in car)\n29 years of experience stories\nFaith journey tied to fitness\nBehind-the-scenes training\nDay-in-the-life content\n\nFORMAT: Storytelling with\nemotional vulnerability\n\nEXAMPLE HOOKS:\n'I slept in my car at 30. At 48...'\n'What 29 years of training taught me'\n'The day I almost quit fitness'","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":189,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":85,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"rectangle","id":"s5-bg","x":0,"y":2750,"width":2400,"height":760,"strokeColor":"#7048e8","backgroundColor":"#d0bfff","seed":190,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false,"roundness":{"type":3}},{"type":"text","id":"s5-title","x":50,"y":2765,"width":2300,"height":35,"text":"3 REEL TEMPLATES (Copy-Paste)","originalText":"3 REEL TEMPLATES (Copy-Paste)","fontSize":26,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#7048e8","backgroundColor":"transparent","seed":191,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"s5-sub","x":50,"y":2802,"width":1800,"height":20,"text":"Use these EXACT structures. Do not freestyle. Pick one template per reel.","originalText":"Use these EXACT structures. Do not freestyle. Pick one template per reel.","fontSize":14,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#7048e8","backgroundColor":"transparent","seed":192,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":60,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"rectangle","id":"t0-bg","x":40,"y":2830,"width":740,"height":670,"strokeColor":"#7048e8","backgroundColor":"#ffffff","seed":193,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false,"roundness":{"type":3}},{"type":"text","id":"t0-title","x":55,"y":2842,"width":710,"height":25,"text":"TEMPLATE 1: THE MYTH BUSTER","originalText":"TEMPLATE 1: THE MYTH BUSTER","fontSize":20,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#7048e8","backgroundColor":"transparent","seed":194,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"t0-sub","x":55,"y":2868,"width":710,"height":18,"text":"Eric Roberts Style","originalText":"Eric Roberts Style","fontSize":14,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#7048e8","backgroundColor":"transparent","seed":195,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":60,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"t0-body","x":55,"y":2892,"width":710,"height":598,"text":"STRUCTURE:\n\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\n0-3s    HOOK (scroll-stopper)\n3-8s    THE LIE (what people believe)\n8-18s   THE TRUTH (with proof/science)\n18-25s  THE FIX (what to do instead)\n25-30s  CTA ('Comment POWER')\n\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\n\nEXAMPLE SCRIPT:\n'I'm sick of trainers telling men over 40\nto do more cardio to lose belly fat.\n\nHere's the truth: excess cardio after 40\nspikes cortisol, which stores MORE belly fat.\n\nInstead, do this 3x/week:\n1. Heavy compound lifts (squat, deadlift)\n2. 20-min HIIT, not 60-min treadmill\n3. Prioritize sleep over extra gym time\n\nComment POWER and I'll send you my\nfree P.O.W.E.R. Method guide.'","originalText":"STRUCTURE:\n\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\n0-3s    HOOK (scroll-stopper)\n3-8s    THE LIE (what people believe)\n8-18s   THE TRUTH (with proof/science)\n18-25s  THE FIX (what to do instead)\n25-30s  CTA ('Comment POWER')\n\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\n\nEXAMPLE SCRIPT:\n'I'm sick of trainers telling men over 40\nto do more cardio to lose belly fat.\n\nHere's the truth: excess cardio after 40\nspikes cortisol, which stores MORE belly fat.\n\nInstead, do this 3x/week:\n1. Heavy compound lifts (squat, deadlift)\n2. 20-min HIIT, not 60-min treadmill\n3. Prioritize sleep over extra gym time\n\nComment POWER and I'll send you my\nfree P.O.W.E.R. Method guide.'","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":196,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":85,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"rectangle","id":"t1-bg","x":810,"y":2830,"width":740,"height":670,"strokeColor":"#7048e8","backgroundColor":"#ffffff","seed":197,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false,"roundness":{"type":3}},{"type":"text","id":"t1-title","x":825,"y":2842,"width":710,"height":25,"text":"TEMPLATE 2: THE PROTOCOL","originalText":"TEMPLATE 2: THE PROTOCOL","fontSize":20,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#7048e8","backgroundColor":"transparent","seed":198,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"t1-sub","x":825,"y":2868,"width":710,"height":18,"text":"RehabFix Style","originalText":"RehabFix Style","fontSize":14,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#7048e8","backgroundColor":"transparent","seed":199,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":60,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"t1-body","x":825,"y":2892,"width":710,"height":598,"text":"STRUCTURE:\n\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\n0-3s    HOOK (problem + promise)\n3-10s   STEP 1 (demonstrate)\n10-18s  STEP 2 (demonstrate)\n18-25s  STEP 3 (demonstrate)\n25-30s  CTA ('Comment TRANSFORM')\n\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\n\nEXAMPLE SCRIPT:\n'3 exercises that fix dad bod posture\nin 2 weeks. Do these daily.\n\nStep 1: Wall angels \u2014 10 reps.\nOpens your chest and fixes rounded\nshoulders from sitting at a desk.\n\nStep 2: Dead hangs \u2014 30 seconds.\nDecompresses your spine instantly.\n\nStep 3: Hip flexor stretch \u2014 60 seconds.\nFixes anterior pelvic tilt.\n\nComment TRANSFORM for my full\n30-day posture protocol (free).'","originalText":"STRUCTURE:\n\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\n0-3s    HOOK (problem + promise)\n3-10s   STEP 1 (demonstrate)\n10-18s  STEP 2 (demonstrate)\n18-25s  STEP 3 (demonstrate)\n25-30s  CTA ('Comment TRANSFORM')\n\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\n\nEXAMPLE SCRIPT:\n'3 exercises that fix dad bod posture\nin 2 weeks. Do these daily.\n\nStep 1: Wall angels \u2014 10 reps.\nOpens your chest and fixes rounded\nshoulders from sitting at a desk.\n\nStep 2: Dead hangs \u2014 30 seconds.\nDecompresses your spine instantly.\n\nStep 3: Hip flexor stretch \u2014 60 seconds.\nFixes anterior pelvic tilt.\n\nComment TRANSFORM for my full\n30-day posture protocol (free).'","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":200,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":85,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"rectangle","id":"t2-bg","x":1580,"y":2830,"width":740,"height":670,"strokeColor":"#7048e8","backgroundColor":"#ffffff","seed":201,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false,"roundness":{"type":3}},{"type":"text","id":"t2-title","x":1595,"y":2842,"width":710,"height":25,"text":"TEMPLATE 3: THE STORY","originalText":"TEMPLATE 3: THE STORY","fontSize":20,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#7048e8","backgroundColor":"transparent","seed":202,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"t2-sub","x":1595,"y":2868,"width":710,"height":18,"text":"LowBackAbility Style","originalText":"LowBackAbility Style","fontSize":14,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#7048e8","backgroundColor":"transparent","seed":203,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":60,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"t2-body","x":1595,"y":2892,"width":710,"height":598,"text":"STRUCTURE:\n\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\n0-3s    HOOK (client's struggle)\n3-12s   THE SITUATION (before)\n12-22s  THE TRANSFORMATION\n22-28s  THE RESULT (proof)\n28-30s  CTA ('Comment FREE')\n\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\n\nEXAMPLE SCRIPT:\n'This CEO came to me at 52, couldn't\nsee his feet. 16 weeks later...\n\nWhen Mike started, he was 265 lbs,\npre-diabetic, sleeping 4 hours a night.\nHis doctor said 'lose weight or medication.'\n\nWe built a P.O.W.E.R. Method plan:\n3 training days, nutrition reset,\nstress protocol for his 80-hr weeks.\n\n16 weeks: down 45 lbs, off pre-diabetes,\nsleeping 7 hours. His doctor was shocked.\n\nComment FREE for the exact protocol\nwe used (it's free).'","originalText":"STRUCTURE:\n\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\n0-3s    HOOK (client's struggle)\n3-12s   THE SITUATION (before)\n12-22s  THE TRANSFORMATION\n22-28s  THE RESULT (proof)\n28-30s  CTA ('Comment FREE')\n\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\n\nEXAMPLE SCRIPT:\n'This CEO came to me at 52, couldn't\nsee his feet. 16 weeks later...\n\nWhen Mike started, he was 265 lbs,\npre-diabetic, sleeping 4 hours a night.\nHis doctor said 'lose weight or medication.'\n\nWe built a P.O.W.E.R. Method plan:\n3 training days, nutrition reset,\nstress protocol for his 80-hr weeks.\n\n16 weeks: down 45 lbs, off pre-diabetes,\nsleeping 7 hours. His doctor was shocked.\n\nComment FREE for the exact protocol\nwe used (it's free).'","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":204,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":85,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"rectangle","id":"s6-bg","x":0,"y":3550,"width":2400,"height":760,"strokeColor":"#f59e0b","backgroundColor":"#fff3bf","seed":205,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false,"roundness":{"type":3}},{"type":"text","id":"s6-title","x":50,"y":3565,"width":2300,"height":35,"text":"CTA & MANYCHAT AUTOMATION","originalText":"CTA & MANYCHAT AUTOMATION","fontSize":26,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#e8590c","backgroundColor":"transparent","seed":206,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"s6-sub","x":