al these)","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#2f9e44","backgroundColor":"transparent","seed":169,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"good-body","x":1235,"y":1822,"width":1080,"height":105,"text":"\u2713  'At 48, I look better than at 28. Here are 3 things I changed.'\n\u2713  'Stop doing crunches if you're over 40. Do this instead.'\n\u2713  'I trained Fortune 500 CEOs for 29 years. Here's the #1 mistake.'\n\u2713  'Men over 40 are doing cardio wrong. Here's proof.'\n\u2713  '3 signs your metabolism is broken (and how to fix it this week)'\n\nWHY THEY WORK: Specific, curiosity-driven, age-targeted, implies expertise","originalText":"\u2713  'At 48, I look better than at 28. Here are 3 things I changed.'\n\u2713  'Stop doing crunches if you're over 40. Do this instead.'\n\u2713  'I trained Fortune 500 CEOs for 29 years. Here's the #1 mistake.'\n\u2713  'Men over 40 are doing cardio wrong. Here's proof.'\n\u2713  '3 signs your metabolism is broken (and how to fix it this week)'\n\nWHY THEY WORK: Specific, curiosity-driven, age-targeted, implies expertise","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#2f9e44","backgroundColor":"transparent","seed":170,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":85,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"rectangle","id":"s4-bg","x":0,"y":2150,"width":2400,"height":560,"strokeColor":"#2f9e44","backgroundColor":"#b2f2bb","seed":171,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":