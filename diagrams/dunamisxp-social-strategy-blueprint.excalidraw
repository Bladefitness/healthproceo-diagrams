":108,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"col1-body","x":55,"y":257,"width":520,"height":330,"text":"933K Followers\n13M views on top reel\n\nWHAT WORKS:\n\u2022 Bold hooks + text overlays on every reel\n\u2022 ManyChat automation:\n  'Comment LAMBORGHINI for free guide'\n\u2022 25,000+ documented transformations\n\u2022 High-energy, gym-floor filming style\n\u2022 Consistent 5+ reels/week posting\n\u2022 Clear niche: body transformation\n\u2022 Every reel has a keyword CTA","originalText":"933K Followers\n13M views on top reel\n\nWHAT WORKS:\n\u2022 Bold hooks + text overlays on every reel\n\u2022 ManyChat automation:\n  'Comment LAMBORGHINI for free guide'\n\u2022 25,000+ documented transformations\n\u2022 High-energy, gym-floor filming style\n\u2022 Consistent 5+ reels/week posting\n\u2022 Clear niche: body transformation\n\u2022 Every reel has a keyword CTA","fontSize":14,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":109,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":90,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"rectangle","id":"col2-bg","x":610,"y":215,"width":550,"height":380,"strokeColor":"#2f9e44","backgroundColor":"#b2f2bb","seed":110,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false,"roundness":{"type":3}},{"type":"text","id":"col2-handle","x":625,"y":225,"width":520,"height":28,"text":"@rehabfix","originalText":"@rehabfix","fontSize":20,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#2f9e44","backgroundColor":"transparent","seed":111,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"col2-body","x":625,"y":257,"width":520,"height":330,"text":"1.3M Followers\nClinical demo format \u2014 millions of views\n\nWHAT WORKS:\n\u2022 Numbered step protocols (3 steps to fix X)\n\u2022 Clinical demonstration on camera\n\u2022 'DM me SCIATICA' keyword CTA\n\u2022 Dr. credentials prominently in bio\n\u2022 Educational authority positioning\n\u2022 Clean, professional studio setup\n\u2022 Consistent branded visual identity","originalText":"1.3M Followers\nClinical demo format \u2014 millions of views\n\nWHAT WORKS:\n\u2022 Numbered step protocols (3 steps to fix X)\n\u2022 Clinical demonstration on camera\n\u2022 'DM me SCIATICA' keyword CTA\n\u2022 Dr. credentials prominently in bio\n\u2022 Educational authority positioning\n\u2022 Clean, professional studio setup\n\u2022 Consistent branded visual identity","fontSize":14,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":112,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":90,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"rectangle","id":"col3-bg","x":1180,"y":215,"width":550,"height":380,"strokeColor":"#7048e8","backgroundColor":"#d0bfff","seed":113,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false,"roundness":{"type":3}},{"type":"text","id":"col3-handle","x":1195,"y":225,"width":520,"height":28,"text":"@lowbackability","originalText":"@lowbackability","fontSize":20,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#7048e8","backgroundColor":"transparent","seed":114,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"col3-body","x":1195,"y":257,"width":520,"height":330,"text":"866K Followers\n94K views on top reel\n\nWHAT WORKS:\n\u2022 Patient testimonial stories (emotional)\n\u2022 'Comment BUILD' \u2192 685 comments per reel\n\u2022 Emotional vulnerability in content\n\u2022 Interview-style patient features\n\u2022 Before/after transformation focus\n\u2022 Story-driven content structure\n\u2022 Strong community engagement","originalText":"866K Followers\n94K views on top reel\n\nWHAT WORKS:\n\u2022 Patient testimonial stories (emotional)\n\u2022 'Comment BUILD' \u2192 685 comments per reel\n\u2022 Emotional vulnerability in content\n\u2022 Interview-style patient features\n\u2022 Before/after transformation focus\n\u2022 Story-driven content structure\n\u2022 Strong community engagement","fontSize":14,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":115,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":90,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"rectangle","id":"col4-bg","x":1750,"y":215,"width":560,"height":380,"strokeColor":"#e03131","backgroundColor":"#fff5f5","seed":116,"versionNonce":0,"isDeleted":false,"fi