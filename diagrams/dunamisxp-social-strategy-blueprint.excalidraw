:20,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#e03131","backgroundColor":"transparent","seed":123,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"gap1-body","x":55,"y":788,"width":1090,"height":127,"text":"Generic openings vs. scroll-stopping first lines\n\nYOUR HOOK: 'God is for you. You might need to hear this.'\nTHEIR HOOK: 'At 48, I look better than at 28. Here are 3 things I changed.'\n\nFIX: Lead with curiosity, numbers, or controversy. Never start with\nmotivational platitudes \u2014 the algorithm punishes slow hooks.","originalText":"Generic openings vs. scroll-stopping first lines\n\nYOUR HOOK: 'God is for you. You might need to hear this.'\nTHEIR HOOK: 'At 48, I look better than at 28. Here are 3 things I changed.'\n\nFIX: Lead with curiosity, numbers, or controversy. Never start with\nmotivational platitudes \u2014 the algorithm punishes slow hooks.","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":124,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":85,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"rectangle","id":"gap2-bg","x":1220,"y":750,"width":1120,"height":175,"strokeColor":"#e03131","backgroundColor":"#ffffff","seed":125,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false,"roundness":{"type":3}},{"type":"text","id":"gap2-title","x":1235,"y":760,"width":1090,"height":25,"text":"GAP 2: VISUAL BRANDING","originalText":"GAP 2: VISUAL BRANDING","fontSize":20,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#e03131","backgroundColor":"transparent","seed":126,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"gap2-body","x":1235,"y":788,"width":1090,"height":127,"text":"Selfie-style filming vs. branded studio setup\n\nYOU: Phone selfie, inconsistent lighting, no text overlays\nTHEM: Ring light, branded backdrop, bold text on every frame\n\nFIX: Set up a filming station ($50 ring light + clean background).\nAdd CapCut text overlays synced to speech on every reel.","originalText":"Selfie-style filming vs. branded studio setup\n\nYOU: Phone selfie, inconsistent lighting, no text overlays\nTHEM: Ring light, branded backdrop, bold text on every frame\n\nFIX: Set up a filming station ($50 ring light + clean background).\nAdd CapCut text overlays synced to speech on every reel.","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":127,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":85,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"rectangle","id":"gap3-bg","x":40,"y":940,"width":1120,"height":175,"strokeColor":"#f59e0b","backgroundColor":"#ffffff","seed":128,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false,"roundness":{"type":3}},{"type":"text","id":"gap3-title","x":55,"y":950,"width":1090,"height":25,"text":"GAP 3: CONTENT STRUCTURE","originalText":"GAP 3: CONTENT STRUCTURE","fontSize":20,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#f59e0b","backgroundColor":"transparent","seed":129,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"gap3-body","x":55,"y":978,"width":1090,"height":127,"text":"Stream of consciousness vs. rigid frameworks\n\nYOU: Freestyle talking with no clear arc\nTHEM: HOOK \u2192 PROBLEM \u2192 SOLUTION \u2192 PROOF \u2192 CTA (every time)\n\nFIX: Use the 3 reel templates below. Never post without\na written outline following one of these structures.","originalText":"Stream of consciousness vs. rigid frameworks\n\nYOU: Freestyle talking with no clear arc\nTHEM: HOOK \u2192 PROBLEM \u2192 SOLUTION \u2192 PROOF \u2192 CTA (every time)\n\nFIX: Use the 3 reel templates below. Never post without\na written outline following one of these structures.","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":130,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":85,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"rectangle","id":"gap4-bg","x":1220,"y":940,"width":1120,"height":175,"strokeColor":"#e03131","backgroundColor":"#ffffff","seed":131,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false,"roundness":{"type":3}},{"type":"text","id":"gap4-title","x":1235,"y":950,"width":1090,"height":25,"text":"GAP 4: CTA & CONVERSION","originalText":"GAP 4: CTA & CONVERSION","fontSize":20,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#e03131","backgroundColor":"transparent","seed":132,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"gap4-body","x":1235,"y":978,"width":1090,"height":127,"text":"'Hit me up' vs. 'Comment POWER'\n\nYOU: Vague 'reach out' with no automation\nTHEM: 'Comment [KEYWORD]' \u2192 ManyChat auto-DM \u2192 lead captured\n\nFIX: Set up ManyChat ($15/mo). End every reel with\n'Comment POWER and I'll send you my free guide.'","originalText":"'Hit me up' vs. 'Comment POWER'\n\nYOU: Vague 'reach out' with no automation\nTHEM: 'Comment [KEYWORD]' \u2192 ManyChat auto-DM \u2192 lead captured\n\nFIX: Set up ManyChat ($15/mo). End every reel with\n'Comment POWER and I'll send you my free guide.'","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":133,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":85,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"rectangle","id":"gap5-bg","x":40,"y":1130,"width":1120,"height":175,"strokeColor":"#f59e0b","backgroundColor":"#ffffff","seed":134,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false,"roundness":{"type":3}},{"type":"text","id":"gap5-title","x":55,"y":1140,"width":1090,"height":25,"text":"GAP 5: NICHE CLARITY","originalText":"GAP 5: NICHE CLARITY","fontSize":20,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#f59e0b","backgroundColor":"transparent","seed":135,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"text","id":"gap5-body","x":55,"y":1168,"width":1090,"height":127,"text":"Faith + fitness + motivation mix vs. single niche\n\nYOU: Mixing faith content, motivational quotes, and fitness tips\nTHEM: ONE topic \u2014 fitness transformation \u2014 every single post\n\nFIX: Lead with fitness transformation for men 35-55.\nFaith can be your brand personality, not your content category.","originalText":"Faith + fitness + motivation mix vs. single niche\n\nYOU: Mixing faith content, motivational quotes, and fitness tips\nTHEM: ONE topic \u2014 fitness transformation \u2014 every single post\n\nFIX: Lead with fitness transformation for men 35-55.\nFaith can be your brand personality, not your content category.","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"autoResize":true,"lineHeight":1.25,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":136,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":85,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},{"type":"rectangle","id":"gap6-bg","x":1220,"y":1130,"width":1120,"height":175,"strokeColor":"#f59e0b","backgroundColor":"#ffffff","seed":137,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"groupIds":[],"frameId":null,"boundElements":null,