    {
      "type": "text",
      "id": "revenue-content",
      "x": 1012.2782616458621,
      "y": 862.7759977449284,
      "width": 600,
      "height": 170,
      "text": "AGENCY:      1 client/mo = $2,500-5,000 setup + $2,500/mo recurring\nAGENTS:      2 clients/mo = $4,000 setup + $1,994/mo recurring\nCOMMUNITY:   20 members/mo (from webinars) = $19,940/mo\nCOURSE:      10 sales/mo = $1,970 + audit upsells\n\nMONTH 3 PROJECTION:\n1 agency ($5K) + 2 agents ($4K) + 20 community ($20K) + courses ($2K)\n= ~$31K/mo + growing recurring base",
      "fontSize": 15,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "AGENCY:      1 client/mo = $2,500-5,000 setup + $2,500/mo recurring\nAGENTS:      2 clients/mo = $4,000 setup + $1,994/mo recurring\nCOMMUNITY:   20 members/mo (from webinars) = $19,940/mo\nCOURSE:      10 sales/mo = $1,970 + audit upsells\n\nMONTH 3 PROJECTION:\n1 agency ($5K) + 2 agents ($4K) + 20 community ($20K) + courses ($2K)\n= ~$31K/mo + growing recurring base",
