    {"type":"text","id":"p2-title","x":70,"y":430,"width":400,"height":30,"text":"PHASE 2 — CLINICAL SETUP","fontSize":24,"fontFamily":1,"textAlign":"left","verticalAlign":"middle","containerId":null,"originalText":"PHASE 2 — CLINICAL SETUP","autoResize":true,"lineHeight":1.25,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":21,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"type":"text","id":"p2-week","x":650,"y":430,"width":180,"height":25,"text":"Weeks 3-6","fontSize":18,"fontFamily":1,"textAlign":"right","verticalAlign":"middle","containerId":null,"originalText":"Weeks 3-6","autoResize":true,"lineHeight":1.25,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":60,"angle":0,"strokeColor":"#22c55e","backgroundColor":"transparent","seed":22,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"type":"text","id":"p2-items","x":80,"y":468,"width":750,"height":200,"text":"1. Treatment protocols & SOPs (Botox, fillers, laser, peels, microneedling, PRP,\n   IV therapy, body contouring, weight loss)\n2. Equipment procurement (laser, microneedling, CoolSculpting, IPL, RF — $50-200K+)\n3. Medical-grade skincare line (ZO Skin Health, SkinMedica, Obagi, or private label)\n4. Supplier accounts (Allergan for Botox/Juvederm, Galderma for Dysport/Restylane)\n5. Emergency protocols — vascular occlusion protocol CRITICAL for fillers\n6. EHR system (Aesthetic Record, PatientNow, or Symplast)\n7. Digital intake forms, consent waivers & before/after photo system\n8. Controlled substance storage & inventory tracking","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"1. Treatment protocols & SOPs (Botox, fillers, laser, peels, microneedling, PRP,\n   IV therapy, body contouring, weight loss)\n2. Equipment procurement (laser, microneedling, CoolSculpting, IPL, RF — $50-200K+)\n3. Medical-grade skincare line (ZO Skin Health, SkinMedica, Obagi, or private label)\n4. Supplier accounts (Allergan for Botox/Juvederm, Galderma for Dysport/Restylane)\n5. Emergency protocols — vascular occlusion protocol CRITICAL for fillers\n6. EHR system (Aesthetic Record, PatientNow, or Symplast)\n7. Digital intake forms, consent waivers & before/after photo system\n8. Controlled substance storage & inventory tracking","autoResize":true,"lineHeight":1.25,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":85,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":23,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},

