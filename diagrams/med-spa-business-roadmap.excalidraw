    {"type":"rectangle","id":"p4-bg","x":50,"y":980,"width":800,"height":220,"roundness":{"type":3},"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#f59e0b","backgroundColor":"#ffd8a8","seed":40,"groupIds":[],"frameId":null,"boundElements":[{"id":"arr-3-4","type":"arrow"},{"id":"arr-4-5","type":"arrow"}],"updated":1,"link":null,"locked":false},
    {"type":"text","id":"p4-title","x":70,"y":990,"width":450,"height":30,"text":"PHASE 4 — BRANDING & DIGITAL","fontSize":24,"fontFamily":1,"textAlign":"left","verticalAlign":"middle","containerId":null,"originalText":"PHASE 4 — BRANDING & DIGITAL","autoResize":true,"lineHeight":1.25,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":41,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"type":"text","id":"p4-week","x":650,"y":990,"width":180,"height":25,"text":"Weeks 6-10","fontSize":18,"fontFamily":1,"textAlign":"right","verticalAlign":"middle","containerId":null,"originalText":"Weeks 6-10","autoResize":true,"lineHeight":1.25,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":60,"angle":0,"strokeColor":"#f59e0b","backgroundColor":"transparent","seed":42,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"type":"text","id":"p4-items","x":80,"y":1028,"width":750,"height":160,"text":"1. Brand identity (luxury/clinical positioning — logo, colors, photography style)\n2. Website (before/after gallery, online booking, SEO-optimized service pages)\n3. Google Business Profile (critical — \"med spa near me\" \"Botox near me\")\n4. Social media (Instagram is KING — before/after transformations, Reels, Stories)\n5. Before/after photo strategy (consistent lighting, angles, consent — this IS your marketing)\n6. Review generation system (Google, RealSelf, Yelp — automate post-treatment requests)\n7. Email/SMS marketing setup (Mailchimp, Klaviyo, or built-in EHR marketing)","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"1. Brand identity (luxury/clinical positioning — logo, colors, photography style)\n2. Website (before/after gallery, online booking, SEO-optimized service pages)\n3. Google Business Profile (critical — \"med spa near me\" \"Botox near me\")\n4. Social media (Instagram is KING — before/after transformations, Reels, Stories)\n5. Before/after photo strategy (consistent lighting, angles, consent — this IS your marketing)\n6. Review generation system (Google, RealSelf, Yelp — automate post-treatment requests)\n7. Email/SMS marketing setup (Mailchimp, Klaviyo, or built-in EHR marketing)","autoResize":true,"lineHeight":1.25,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":85,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":43,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},

