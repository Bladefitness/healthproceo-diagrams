    {"type":"text","id":"sb-menu-body","x":935,"y":805,"width":260,"height":420,"text":"INJECTABLES:\nBotox/Dysport      $12-15/unit\nLip Filler         $650-850\nCheek/Jaw Filler   $750-1,200\nKybella            $600-800/vial\n\nSKIN TREATMENTS:\nChemical Peel      $150-300\nMicroneedling      $300-500\nRF Microneedling   $500-800\nIPL Photofacial    $300-500\nLaser Hair Removal $150-400/area\n\nBODY:\nCoolSculpting      $750-1,500/area\nBody Contouring    $2,000-5,000/pkg\n\nWEIGHT LOSS:\nSemaglutide        $399-599/mo\n\nADD-ONS:\nPRP                $400-600\nLED Therapy        $75-150","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"INJECTABLES:\nBotox/Dysport      $12-15/unit\nLip Filler         $650-850\nCheek/Jaw Filler   $750-1,200\nKybella            $600-800/vial\n\nSKIN TREATMENTS:\nChemical Peel      $150-300\nMicroneedling      $300-500\nRF Microneedling   $500-800\nIPL Photofacial    $300-500\nLaser Hair Removal $150-400/area\n\nBODY:\nCoolSculpting      $750-1,500/area\nBody Contouring    $2,000-5,000/pkg\n\nWEIGHT LOSS:\nSemaglutide        $399-599/mo\n\nADD-ONS:\nPRP                $400-600\nLED Therapy        $75-150","autoResize":true,"lineHeight":1.25,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":85,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":112,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},

