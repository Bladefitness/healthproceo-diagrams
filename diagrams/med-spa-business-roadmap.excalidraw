    {"type":"text","id":"p3-title","x":70,"y":720,"width":400,"height":30,"text":"PHASE 3 — OPERATIONS","fontSize":24,"fontFamily":1,"textAlign":"left","verticalAlign":"middle","containerId":null,"originalText":"PHASE 3 — OPERATIONS","autoResize":true,"lineHeight":1.25,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":31,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"type":"text","id":"p3-week","x":650,"y":720,"width":180,"height":25,"text":"Weeks 5-8","fontSize":18,"fontFamily":1,"textAlign":"right","verticalAlign":"middle","containerId":null,"originalText":"Weeks 5-8","autoResize":true,"lineHeight":1.25,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":60,"angle":0,"strokeColor":"#8b5cf6","backgroundColor":"transparent","seed":32,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"type":"text","id":"p3-items","x":80,"y":758,"width":750,"height":180,"text":"1. Service menu & pricing strategy (competitive market analysis)\n2. Booking system (Vagaro, Boulevard, or Aesthetic Record built-in)\n3. Payment processing + financing (Cherry, PatientFi, CareCredit — critical for $2K+ treatments)\n4. Membership program design ($99-299/mo — Botox units, discounts, perks)\n5. Staffing plan (injectors, estheticians, laser techs, front desk — W2 vs 1099)\n6. Compensation structure (base + commission on sales + product commission)\n7. Standard operating procedures (check-in, consult, treatment, aftercare, follow-up)\n8. Inventory management & reorder system","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"1. Service menu & pricing strategy (competitive market analysis)\n2. Booking system (Vagaro, Boulevard, or Aesthetic Record built-in)\n3. Payment processing + financing (Cherry, PatientFi, CareCredit — critical for $2K+ treatments)\n4. Membership program design ($99-299/mo — Botox units, discounts, perks)\n5. Staffing plan (injectors, estheticians, laser techs, front desk — W2 vs 1099)\n6. Compensation structure (base + commission on sales + product commission)\n7. Standard operating procedures (check-in, consult, treatment, aftercare, follow-up)\n8. Inventory management & reorder system","autoResize":true,"lineHeight":1.25,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":85,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":33,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},

