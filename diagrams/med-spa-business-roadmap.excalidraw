    {"type":"text","id":"sb-tips-body","x":935,"y":1635,"width":260,"height":170,"text":"- Memberships = KEY to\n  predictable revenue\n- Botox is the gateway drug\n  to everything else\n- Before/after photos are\n  your #1 marketing asset\n- Semaglutide = highest\n  demand service right now\n- Financing (Cherry, PatientFi)\n  increases tickets 40-60%\n- Retail skincare = pure margin","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"- Memberships = KEY to\n  predictable revenue\n- Botox is the gateway drug\n  to everything else\n- Before/after photos are\n  your #1 marketing asset\n- Semaglutide = highest\n  demand service right now\n- Financing (Cherry, PatientFi)\n  increases tickets 40-60%\n- Retail skincare = pure margin","autoResize":true,"lineHeight":1.25,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":85,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":132,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false}
