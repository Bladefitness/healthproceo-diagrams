    {"type":"text","id":"p1-title","x":70,"y":120,"width":400,"height":30,"text":"PHASE 1 — FOUNDATION","fontSize":24,"fontFamily":1,"textAlign":"left","verticalAlign":"middle","containerId":null,"originalText":"PHASE 1 — FOUNDATION","autoResize":true,"lineHeight":1.25,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":11,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"type":"text","id":"p1-week","x":650,"y":120,"width":180,"height":25,"text":"Weeks 1-4","fontSize":18,"fontFamily":1,"textAlign":"right","verticalAlign":"middle","containerId":null,"originalText":"Weeks 1-4","autoResize":true,"lineHeight":1.25,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":60,"angle":0,"strokeColor":"#4a9eed","backgroundColor":"transparent","seed":12,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"type":"text","id":"p1-items","x":80,"y":158,"width":750,"height":220,"text":"1. Business entity formation (LLC or PLLC depending on state)\n2. Medical Director agreement (MD/DO — required in most states, $2-5K/mo)\n3. State medical board licensing & compliance (scope of practice for NPs, PAs, RNs)\n4. Facility lease & buildout (1,200-2,500 sq ft — treatment rooms, reception, storage)\n5. Business insurance (malpractice + general liability + property)\n6. DEA registration (if offering ketamine, weight loss injectables)\n7. HIPAA compliance (EHR, BAA with vendors, encrypted systems)\n8. Business bank account, merchant processing & accounting (QuickBooks)\n9. OSHA compliance (bloodborne pathogens, sharps disposal, infection control)","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"1. Business entity formation (LLC or PLLC depending on state)\n2. Medical Director agreement (MD/DO — required in most states, $2-5K/mo)\n3. State medical board licensing & compliance (scope of practice for NPs, PAs, RNs)\n4. Facility lease & buildout (1,200-2,500 sq ft — treatment rooms, reception, storage)\n5. Business insurance (malpractice + general liability + property)\n6. DEA registration (if offering ketamine, weight loss injectables)\n7. HIPAA compliance (EHR, BAA with vendors, encrypted systems)\n8. Business bank account, merchant processing & accounting (QuickBooks)\n9. OSHA compliance (bloodborne pathogens, sharps disposal, infection control)","autoResize":true,"lineHeight":1.25,"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":85,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":13,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},

    {"type":"arrow","id":"arr-1-2","x":450,"y":390,"width":0,"height":30,"points":[[0,0],[0,30]],"startArrowhead":null,"endArrowhead":"arrow","startBinding":{"elementId":"p1-bg","focus":0,"gap":1,"fixedPoint":[0.5,1]},"endBinding":{"elementId":"p2-bg","focus":0,"gap":1,"fixedPoint":[0.5,0]},"versionNonce":0,"isDeleted":false,"fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","seed":14,"groupIds":[],"frameId":null,"boundElements":null,"updated":1,"link":null,"locked":false},

